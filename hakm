#!/usr/bin/env sh
# hakm — standalone runner for hako-* models.
# v0: thin shell wrapper over `ollama`. Native C runner (hakm-server) planned for v0.1.7.
#
# Usage:
#   hakm run <model> <prompt>     run model with prompt (one-shot)
#   hakm chat <model>             interactive chat (passthrough to `ollama run`)
#   hakm list                     list installed hako-* models
#   hakm pull <model>             ensure hako-<model> is available locally
#   hakm models                   list known hako-* model catalog
#   hakm -h | --help              this help
#   hakm -v | --version           print version
#
# Naming: `hakm <short>` resolves <short> to its current tag.
#   `hakm run sho "..."`      → `ollama run hako-sho-stock "..."`
#   `hakm run koi-mini "..."` → `ollama run hako-koi-mini-stock "..."`
#
# Env:
#   HAKM_REGISTRY=ollama   transport (only ollama supported in v0)

set -eu

HAKM_VERSION="0.1.0"
HAKM_REGISTRY="${HAKM_REGISTRY:-ollama}"

# Live catalog. Stock-wraps carry no version; first real fine-tune earns v0.0.1.
TAG_SHO="hako-sho-stock"            # mini      · Qwen2.5-Coder-3B  · live
TAG_KOI_MINI="hako-koi-mini-stock"  # mid-small · Qwen2.5-Coder-7B  · live

die() { echo "hakm: $*" >&2; exit 1; }

require_ollama() {
	command -v ollama >/dev/null 2>&1 || die "ollama not found on PATH. install: https://ollama.com"
}

resolve_short() {
	# Maps short alias to full model tag.
	case "$1" in
		sho)        echo "$TAG_SHO" ;;
		koi-mini)   echo "$TAG_KOI_MINI" ;;
		koi)        die "koi (mid · 14B/32B) is queued — real fine-tune lands after the rented-GPU run. today: sho, koi-mini" ;;
		samurai)    die "samurai (max · 50B+) is reserved — waits on hardware. today: sho, koi-mini" ;;
		hako-*)     echo "$1" ;;                    # already full tag
		*)          die "unknown model: $1 (try: sho, koi-mini)" ;;
	esac
}

# Create a stock-wrap from its base + bundled Modelfile.
pull_stock() {
	tag="$1"; base="$2"; dir="$3"
	ollama list 2>/dev/null | grep -q "^${tag}\b" && { echo "$tag already installed."; return 0; }
	ollama pull "$base"
	modelfile_dir="$(dirname "$0")/$dir"
	[ -f "$modelfile_dir/Modelfile" ] || die "Modelfile not found at $modelfile_dir/Modelfile"
	(cd "$modelfile_dir" && ollama create "$tag" -f Modelfile)
}

usage() {
	sed -n '2,21p' "$0" | sed 's/^# //; s/^#//'
}

cmd="${1:-}"
case "$cmd" in
	-h|--help|help|"")
		usage
		;;
	-v|--version)
		echo "hakm $HAKM_VERSION"
		;;
	run)
		[ $# -ge 3 ] || die "usage: hakm run <model> <prompt>"
		require_ollama
		model="$(resolve_short "$2")"
		shift 2
		exec ollama run "$model" "$*"
		;;
	chat)
		[ $# -ge 2 ] || die "usage: hakm chat <model>"
		require_ollama
		model="$(resolve_short "$2")"
		exec ollama run "$model"
		;;
	list)
		require_ollama
		ollama list 2>/dev/null | awk 'NR==1 || /^hako-/'
		;;
	serve)
		# v0.1.6: stub. Real `hakm-server` (vendored llama.cpp subset) lands v0.1.7.
		# Until then, anything wanting an inference server should start `ollama serve`.
		echo "hakm serve: native engine not built yet (planned v0.1.7)." >&2
		echo "for now run 'ollama serve' — hakm and the hako agent talk to localhost:11434." >&2
		exit 1
		;;
	pull)
		[ $# -ge 2 ] || die "usage: hakm pull <model>"
		require_ollama
		case "$2" in
			sho)        pull_stock "$TAG_SHO"      "qwen2.5-coder:3b-instruct" "sho/models/hako-sho-stock" ;;
			koi-mini)   pull_stock "$TAG_KOI_MINI" "qwen2.5-coder:7b-instruct" "koi/models/hako-koi-mini-stock" ;;
			koi)        die "koi (mid · 14B/32B) is queued — no pull recipe yet" ;;
			samurai)    die "samurai (max · 50B+) is reserved — no pull recipe yet" ;;
			*)          die "no pull recipe for $2 (try: sho, koi-mini)" ;;
		esac
		;;
	models)
		printf 'short\t\ttag\t\t\ttier\t\tstatus\n'
		printf 'sho\t\t%s\t\tmini\t\tlive\n'      "$TAG_SHO"
		printf 'koi-mini\t%s\tmid-small\tlive\n'  "$TAG_KOI_MINI"
		printf 'koi\t\t-\t\t\tmid\t\tqueued\n'
		printf 'samurai\t\t-\t\t\tmax\t\treserved\n'
		;;
	*)
		die "unknown command: $cmd (try: hakm --help)"
		;;
esac
